/CharBuilder
{
/ch-code exch def
/font-dict exch def
/ch-data font-dict /BitMaps get
ch-code get def
ch-data null eq not
{
ch-tfmw 0
ch-xoff neg ch-yoff ch-height sub
ch-width ch-xoff sub ch-yoff
setcachedevice
0 0 SNAP translate
ch-width ch-height true [ 1 0 0 -1 ch-xoff ch-yoff ]
