300 1972 56 (----) 56 SB
300 2022 517 (template <class T> void f1\(T\);) 517 SB
300 2072 517 (template <class T> void f2\(T\);) 517 SB
300 2122 517 (template <class T> void f3\(T\);) 517 SB
300 2222 528 (template <class T> void f1\(T t\)) 528 SB
300 2272 20 ({) 20 SB
450 2322 86 (f2\(t\);) 86 SB
