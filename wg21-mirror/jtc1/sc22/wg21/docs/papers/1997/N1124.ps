-0.200 0 (             enum A { a = 1U, b = a-2, c = -1 };)A 
; : 161 2054 1925 45 rc 0 0 0 sco F0_42
Ji 
161 2054 M 
-0.200 0 (         The underlying type will clearly be signed.  Does "b" have the value)A 
; : 161 2099 1000 45 rc 0 0 0 sco F0_42
Ji 
161 2099 M 
-0.200 0 (         "-1" or is the code ill-formed?)A 
; : 161 2189 1725 45 rc 0 0 0 sco F0_42
Ji 
161 2189 M 
-0.200 0 (         There seem to be several possible solutions to this problem:)A 
; : 161 2279 1775 45 rc 0 0 0 sco F0_42
Ji 
161 2279 M 
-0.200 0 (          1\) When an enumerator is used in the defining expression of a)A 
; : 161 2324 1875 45 rc 0 0 0 sco F0_42
Ji 
