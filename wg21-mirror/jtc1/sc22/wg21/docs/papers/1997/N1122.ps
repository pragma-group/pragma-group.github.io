; : 161 2234 1025 45 rc 0 0 0 sco F0_42
Ji 
161 2234 M 
-0.200 0 (               p->A::template B<T>::~B\(\);)A 
; : 161 2279 850 45 rc 0 0 0 sco F0_42
Ji 
161 2279 M 
-0.200 0 (                     -------------)A 
; : 161 2369 1900 45 rc 0 0 0 sco F0_42
Ji 
161 2369 M 
-0.200 0 (         After discussions with Bill Gibbons, John Spicer, Anthony Scian and)A 
; : 161 2414 1950 45 rc 0 0 0 sco F0_42
Ji 
161 2414 M 
