; : 161 2054 650 45 rc 0 0 0 sco F0_42
Ji 
161 2054 M 
-0.200 0 (         In qualified-ids:)A 
; : 161 2099 1225 45 rc 0 0 0 sco F0_42
Ji 
161 2099 M 
-0.200 0 (               A<T>::template B<X>::template C<Y>)A 
; : 161 2144 850 45 rc 0 0 0 sco F0_42
Ji 
161 2144 M 
-0.200 0 (                     -------------)A 
; : 161 2189 900 45 rc 0 0 0 sco F0_42
