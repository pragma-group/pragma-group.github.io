           struct C;
           void no_opt(C*);

           struct C {
               int c;
               C() : c(0) { no_opt(this); }
           };

           const C cobj;

           void no_opt(C *cptr)
           {
               int i = cobj.c * 100;
               cptr->c = 1; // must the implementation assume that
                            // cobj is modified by this assignment?
               cout << cobj.c * 100 << '\n';
           }
