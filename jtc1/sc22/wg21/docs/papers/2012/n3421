#include <iterator>
#include <ostream>
#include <set>
#include <string>
#include <vector>
using namespace std;

int main() {
    vector<const char *> v;
    v.push_back("cute");
    v.push_back("fluffy");
    v.push_back("kittens");

    set<string, greater<>> s;
    s.insert("HUNGRY");
    s.insert("EVIL");
    s.insert("ZOMBIES");

    vector<string> dest;

    transform(v.begin(), v.end(), s.begin(), back_inserter(dest), plus<>());

    for (const auto& elem : dest) {
        cout << elem << endl;
    }
}

