	/bitson{/ybit xdf/xbit xdf/bytevalue bstring ybit bwidth mul xbit 8 idiv add get def
		/mask 1 7 xbit 8 mod sub bitshift def bytevalue mask and 0 ne}def
end
/bitpatternspotfunction{setpatterndict begin
	/y xdf/x xdf/xindex x 1 add 2 div bpside mul cvi def/yindex y 1 add 2 div bpside mul cvi def
	xindex yindex bitson{/onbits onbits 1 add def 1}{/offbits offbits 1 add def 0}ifelse end}def
/setpattern
{setpatterndict begin
	/cellsz xdf/bwidth xdf/bpside xdf/bstring xdf/onbits 0 def/offbits 0 def cellsz/bitpatternspotfunction load
	setuserscreen{}settransfer offbits offbits onbits add div setgray end}def
