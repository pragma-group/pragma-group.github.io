namespace std {
  template<class T, class M = void> class valarray; // An array of type T
  class slice;                                      // A BLAS-like slice
                                                    // out of an array
 
  // Unary operators
  template<class T, class M> valarray<T, R6>
    operator+(const valarray<T, M>&);
  template<class T, class M> valarray<T, R7>
    operator-(const valarray<T, M>&);
